// ---------- DNS settings ----------
const byte DNS_PORT = 53;
DNSServer dnsServer;

// ---------- Web server ----------
WebServer server(80);

// ---------- OTP state (server-side) ----------
String currentOTP = "000000";
unsigned long lastOtpUpdate = 0;
const unsigned long otpIntervalMs = 5000; // rotate OTP every 5 seconds

// Generate a 6-digit OTP with unique digits (0–9, no repeats)
String generateOtp() {
  int digits[10];
  for (int i = 0; i < 10; i++) digits[i] = i;

  // Fisher–Yates shuffle
  for (int i = 9; i > 0; i--) {
    int j = random(0, i + 1);
    int temp = digits[i];
    digits[i] = digits[j];
    digits[j] = temp;
  }

  char buf[7];
  for (int i = 0; i < 6; i++) {
    buf[i] = '0' + digits[i];
  }
  buf[6] = '\0';
  return String(buf);
}

