// ---------- Handlers ----------

// Serve your project page with current OTP inserted
void handleProjectPage() {
  // Build HTML from template and replace %OTP% with current OTP
  String page = FPSTR(PROJECT_HTML_TEMPLATE);
  page.replace("%OTP%", currentOTP);

  // Avoid caching: always get fresh page
  server.sendHeader("Cache-Control", "no-store, no-cache, must-revalidate, max-age=0");
  server.sendHeader("Pragma", "no-cache");
  server.sendHeader("Expires", "-1");
  server.send(200, "text/html", page);
}

// Redirect any other request to /cpsproject/project.html
void handleRedirect() {
  server.sendHeader("Location", String("/cpsproject/project.html"), true);
  server.send(302, "text/plain", "");
}

void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println();
  Serial.println("Starting CPS Project captive portal...");

  // Seed RNG & initial OTP
  randomSeed(micros());
  currentOTP = generateOtp();
  lastOtpUpdate = millis();
  Serial.print("Initial OTP: ");
  Serial.println(currentOTP);

  // 1) Start WiFi in AP mode
  WiFi.mode(WIFI_AP);
  WiFi.softAPConfig(apIP, apIP, netMsk);
  WiFi.softAP(AP_SSID, AP_PASSWORD);

  Serial.print("AP started. SSID: ");
  Serial.println(AP_SSID);
  Serial.print("AP IP address: ");
  Serial.println(WiFi.softAPIP());

  // 2) Start DNS server – send ALL domains to our AP IP
  dnsServer.start(DNS_PORT, "*", apIP);

  // 3) Configure HTTP server routes
  server.on("/cpsproject/project.html", HTTP_GET, handleProjectPage);

  // Captive portal redirect routes
  server.on("/", HTTP_GET, handleRedirect);
  server.on("/generate_204", HTTP_GET, handleRedirect);  // Android
  server.on("/fwlink", HTTP_GET, handleRedirect);        // Windows
  server.onNotFound(handleRedirect);                     // Anything else

  server.begin();
  Serial.println("HTTP server started.");
}

void loop() {
  // Rotate OTP on server every otpIntervalMs
  unsigned long now = millis();
  if (now - lastOtpUpdate >= otpIntervalMs) {
    lastOtpUpdate = now;
    currentOTP = generateOtp();
    Serial.print("Auto-rotated OTP: ");
    Serial.println(currentOTP);
  }

  // Keep DNS and HTTP servers running
  dnsServer.processNextRequest();
  server.handleClient();
}
